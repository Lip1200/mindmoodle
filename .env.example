# Mental Health Chatbot - Environment Variables
# Copy this file to .env and fill in your values

# === Chainlit Configuration ===
CHAINLIT_AUTH_SECRET=your-super-secret-key-change-me-in-production
CHAINLIT_URL=https://your-domain.com

# === LLM API Keys ===
# Add the API key for your chosen LLM provider
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# === Application Settings ===
COMPANION=dog
CHAINLIT_TELEMETRY=false

# === DigitalOcean Deployment ===
# Your droplet IP or domain
DROPLET_IP=your.droplet.ip.address
DOMAIN=chatbot.yourdomain.com
